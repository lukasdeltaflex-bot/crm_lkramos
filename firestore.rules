rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para o usuário gerenciar sua própria pasta e subcoleções (Follow-ups, Lembretes, Perfil)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regras para clientes e propostas (protegidas por ownerId no código)
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }
    match /loanProposals/{proposalId} {
      allow read, write: if request.auth != null;
    }
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Fallback de Debug (Manter fechado em produção real)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
