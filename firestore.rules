
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only manage their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      // Allow authenticated users to read. The client-side code is responsible
      // for filtering to only show the user's own customers via a where() clause.
      allow read: if request.auth != null;
      
      // Users can create, update, or delete a customer document if they are the owner.
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /loanProposals/{loanProposalId} {
      // Allow authenticated users to read. The client-side code is responsible
      // for filtering to only show the user's own proposals via a where() clause.
      allow read: if request.auth != null;

      // Users can create, update, or delete proposals they own.
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // User settings can only be managed by the owner.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products are read-only for authenticated users.
    match /products/{productId} {
        allow read: if request.auth != null;
        allow write: if false;
    }
  }
}
