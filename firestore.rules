
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only manage their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      // Allow any authenticated user to read (list/get). 
      // The client-side query is responsible for filtering.
      allow read: if request.auth != null;
      
      // Writes are restricted to the owner.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /loanProposals/{loanProposalId} {
      // Allow any authenticated user to read (list/get). 
      allow read: if request.auth != null;
      
      // Writes are restricted to the owner.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // User settings can only be managed by the owner.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products are read-only for authenticated users.
    match /products/{productId} {
        allow read: if request.auth != null;
        allow write: if false;
    }
  }
}
