rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar propriedade do documento (usada em get/write)
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Regras para Perfis de Usuário
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Regras para Clientes (usam ownerId)
    match /customers/{customerId} {
      allow list: if request.auth != null && request.query.where('ownerId', '==', request.auth.uid);
      allow get: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Regras para Propostas (usam ownerId)
    match /loanProposals/{proposalId} {
      allow list: if request.auth != null && request.query.where('ownerId', '==', request.auth.uid);
      allow get: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Regras para Lembretes (usam userId)
    match /reminders/{reminderId} {
      // ✅ PERMITE QUERY (list) exigindo o filtro userId no código
      allow list: if request.auth != null 
        && request.query.where('userId', '==', request.auth.uid);

      // ✅ PERMITE LEITURA DE DOC INDIVIDUAL
      allow get: if request.auth != null 
        && resource.data.userId == request.auth.uid;

      // ✅ CRIAÇÃO
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;

      // ✅ ATUALIZAÇÃO / DELETE
      allow update, delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
    }

    // Regras para Configurações do Usuário
    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Bloqueio padrão para qualquer outra rota não mapeada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}