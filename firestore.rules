rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra específica para clientes
    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Regra para todas as outras coleções
    match /{path=**}/documents/{document} {
      // Mantém as permissões para outras coleções (propostas, etc.)
      // para evitar que o resto do aplicativo pare de funcionar.
      allow read, write: if request.auth != null;
    }
  }
}