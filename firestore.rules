rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Regras para Perfis de Usuário
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Regras para Clientes (usam ownerId)
    match /customers/{customerId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid || request.resource.data.ownerId == request.auth.uid);
    }

    // Regras para Propostas (usam ownerId)
    match /loanProposals/{proposalId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid || request.resource.data.ownerId == request.auth.uid);
    }

    // Regras para Lembretes (usam userId)
    match /reminders/{reminderId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    // Regras para Configurações do Usuário
    match /userSettings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Bloqueio de qualquer outro acesso não especificado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}