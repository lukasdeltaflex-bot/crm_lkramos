rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userIdField) {
      return isAuthenticated() && (
        (resource == null) || 
        (resource.data.get(userIdField, '') == request.auth.uid)
      );
    }

    function willBeOwner(userIdField) {
      return isAuthenticated() && request.resource.data.get(userIdField, '') == request.auth.uid;
    }

    // Regras para Perfis de Usuário
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Regras para Clientes (usam ownerId)
    match /customers/{customerId} {
      allow read: if isOwner('ownerId');
      allow write: if willBeOwner('ownerId') || isOwner('ownerId');
    }

    // Regras para Propostas (usam ownerId)
    match /loanProposals/{proposalId} {
      allow read: if isOwner('ownerId');
      allow write: if willBeOwner('ownerId') || isOwner('ownerId');
    }

    // Regras para Lembretes (usam userId)
    match /reminders/{reminderId} {
      allow read: if isOwner('userId');
      allow write: if willBeOwner('userId') || isOwner('userId');
    }

    // Regras para Configurações do Usuário
    match /userSettings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Bloqueio de qualquer outro acesso não especificado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}