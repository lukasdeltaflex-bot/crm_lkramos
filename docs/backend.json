
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Stores user profile information.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User ID, same as Firebase Auth UID."
        },
        "fullName": {
          "type": "string",
          "description": "User's full name."
        },
        "displayName": {
          "type": "string",
          "description": "How the user wants to be called."
        },
        "photoURL": {
          "type": "string",
          "description": "URL for the user's profile picture."
        },
        "birthDate": {
          "type": "string",
          "description": "User's birth date.",
          "format": "date"
        },
        "phone": {
          "type": "string",
          "description": "User's phone number."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        }
      },
      "required": [
        "uid",
        "email"
      ]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer who is an INSS retiree or pensioner.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Customer entity."
        },
        "numericId": {
            "type": "number",
            "description": "User-facing numeric identifier for the customer."
        },
        "name": {
          "type": "string",
          "description": "Full name of the customer."
        },
        "cpf": {
          "type": "string",
          "description": "Customer's CPF."
        },
        "benefits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "number": { "type": "string" },
                "species": { "type": "string" }
              }
            }
        },
        "phone": { "type": "string" },
        "phone2": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "birthDate": { "type": "string", "format": "date" },
        "ownerId": { "type": "string" },
        "cep": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "complement": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "documents": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/Attachment" }
        },
        "observations": { "type": "string" }
      },
      "required": ["numericId", "name", "cpf", "phone", "birthDate", "ownerId"]
    },
    "Attachment": {
      "title": "Attachment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" }
      },
      "required": ["name", "url", "type", "size"]
    },
    "LoanProposal": {
      "title": "LoanProposal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "customerId": { "type": "string" },
        "proposalNumber": { "type": "string" },
        "status": { "type": "string" },
        "grossAmount": { "type": "number" },
        "netAmount": { "type": "number" },
        "commissionValue": { "type": "number" },
        "commissionStatus": { "type": "string" },
        "dateDigitized": { "type": "string", "format": "date-time" },
        "dateApproved": { "type": "string", "format": "date-time" }
      }
    },
    "Reminder": {
      "title": "Reminder",
      "type": "object",
      "description": "A scheduled task or reminder for a customer or prospect.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "Title or client name." },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "customerId": { "type": "string", "description": "Optional link to existing Customer." },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "dueDate", "status", "ownerId"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "type": "object",
      "properties": {
        "productTypes": { "type": "array", "items": { "type": "string" } },
        "proposalStatuses": { "type": "array", "items": { "type": "string" } },
        "commissionStatuses": { "type": "array", "items": { "type": "string" } },
        "approvingBodies": { "type": "array", "items": { "type": "string" } },
        "banks": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/customers/{customerId}", "definition": { "entityName": "Customer" } },
      { "path": "/loanProposals/{loanProposalId}", "definition": { "entityName": "LoanProposal" } },
      { "path": "/reminders/{reminderId}", "definition": { "entityName": "Reminder" } },
      { "path": "/userSettings/{userId}", "definition": { "entityName": "UserSettings" } }
    ]
  }
}
