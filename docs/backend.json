
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Stores user profile information.",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["uid", "email"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "numericId": { "type": "number" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "phone": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["numericId", "name", "cpf", "phone", "ownerId"]
    },
    "LoanProposal": {
      "title": "LoanProposal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "customerId": { "type": "string" },
        "proposalNumber": { "type": "string" },
        "status": { "type": "string" },
        "observations": { "type": "string", "description": "Observações gerais ou motivo de reprova, especialmente para portabilidade." }
      }
    },
    "FollowUp": {
      "title": "FollowUp",
      "type": "object",
      "description": "Mecanismo de retornos futuros para clientes ou leads.",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "contactName": { "type": "string" },
        "contactPhone": { "type": "string" },
        "customerId": { "type": "string" },
        "referralInfo": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "completed", "rescheduled", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["ownerId", "contactName", "dueDate", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/users/{userId}/followUps/{followUpId}", "definition": { "entityName": "FollowUp" } },
      { "path": "/customers/{customerId}", "definition": { "entityName": "Customer" } },
      { "path": "/loanProposals/{loanProposalId}", "definition": { "entityName": "LoanProposal" } },
      { "path": "/userSettings/{userId}", "definition": { "entityName": "UserSettings" } }
    ]
  }
}
